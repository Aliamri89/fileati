# REQUIRED. Long random string used to sign Payload CMS auth tokens. The app
# refuses to start without it ("missing secret key" error). Generate one with
# `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
# and never reuse the same value across environments (dev/staging/prod each
# need their own).
PAYLOAD_SECRET=

# REQUIRED. SQLite database file used by Payload CMS (libSQL client URL
# format, not a traditional DB connection string — there is no external
# database service to provision). In production this must point to a path
# on persistent storage that survives redeploys; the default here is only
# correct for local development.
DATABASE_URI=file:./tampdf.db

# OPTIONAL. The site's real public origin, e.g. https://tampdf.com (no
# trailing path). When set, Payload enforces a CSRF origin allowlist for
# authenticated admin/API requests. Safe to leave unset — origin-checking
# is simply skipped, which is fine for this single-admin app — but
# recommended once the production domain is live.
SERVER_URL=
